# Copy to .env and fill in values before running Scout

# Local default: API callers send this value in X-API-Key.
# Change before exposing Scout beyond local development.
SCOUT_API_KEY=dev-key

# Required for /extract endpoint (LLM structured extraction)
# Default provider: gemini/gemini-2.0-flash
LLM_API_KEY=

# Optional overrides
HOST=0.0.0.0
PORT=8421
