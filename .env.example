# Copy to .env.local for local development and fill in values before running Scout.
# Keep .env.local private. It is ignored by git and should hold local keys/config.

# Local default: API callers send this value in X-API-Key.
# Change before exposing Scout beyond local development.
SCOUT_API_KEY=dev-key

# Optional local-only LLM structured extraction key. Do not set this in hosted
# production unless SCOUT_HOSTED_LLM_MODE and allowlists are deliberately
# configured. Hosted production defaults to LLM disabled to prevent surprise
# model bills.
LLM_API_KEY=

# Base directory where Scout writes run artifacts when --output-dir is omitted.
# CLI prompts for this value in interactive sessions; HTTP and scheduled runs use
# this value without prompting.
SCOUT_WORKDIR=scout-runs

# Optional persistence overrides. Leave blank to store SQLite files under SCOUT_WORKDIR.
DB_PATH=
HOSTED_ACCOUNT_DB_PATH=

# Optional hosted Stripe Checkout. Required only for paid hosted beta.
STRIPE_SECRET_KEY=
# Legacy fallback only. New paid packages should use package-specific price IDs below.
STRIPE_BETA_PRICE_ID=
STRIPE_STANDARD_1000_PRICE_ID=
STRIPE_STANDARD_3000_PRICE_ID=
STRIPE_STANDARD_15000_PRICE_ID=
STRIPE_BROWSER_100_PRICE_ID=
STRIPE_UNLIMITED_PRICE_ID=
STRIPE_SUCCESS_URL=https://scout.chowmes.com/pricing?checkout=success
STRIPE_CANCEL_URL=https://scout.chowmes.com/pricing?checkout=cancelled
STRIPE_BETA_SUCCESS_URL=https://scout.chowmes.com/beta?checkout=success
STRIPE_BETA_CANCEL_URL=https://scout.chowmes.com/beta?checkout=cancelled
STRIPE_PORTAL_RETURN_URL=https://scout.chowmes.com/account

# Optional Stripe webhook signature secret. Required for payment-confirmed key provisioning.
STRIPE_WEBHOOK_SECRET=

# Optional SMTP delivery for one-time hosted API keys.
# If host/from-email are blank, hosted Stripe webhook provisioning stays safely disabled.
HOSTED_KEY_DELIVERY_SMTP_HOST=
HOSTED_KEY_DELIVERY_SMTP_PORT=587
HOSTED_KEY_DELIVERY_SMTP_FROM_EMAIL=
HOSTED_KEY_DELIVERY_SMTP_USERNAME=
HOSTED_KEY_DELIVERY_SMTP_PASSWORD=
HOSTED_KEY_DELIVERY_SMTP_USE_TLS=true

# Hosted API private-beta rate limits. This is per process; use a distributed
# limiter such as Redis before multi-instance hosted production.
HOSTED_RATE_LIMIT_MAX_REQUESTS=60
HOSTED_RATE_LIMIT_WINDOW_SECONDS=60
HOSTED_MAX_ACTIVE_REQUESTS=8
HOSTED_JOB_QUEUE_MAX_SIZE=250
HOSTED_JOB_QUEUE_WORKERS=2
HOSTED_ASYNC_FIRST=false
PLAYGROUND_MAX_ACTIVE_REQUESTS=4
CAPACITY_RETRY_AFTER_SECONDS=5

# Hosted beta email signup. Leave false unless key generation, rate limits,
# low credits, monitoring, and kill switches are ready.
HOSTED_BETA_SIGNUP_ENABLED=false
HOSTED_BETA_SIGNUP_RATE_LIMIT_MAX_REQUESTS=3
HOSTED_BETA_SIGNUP_RATE_LIMIT_WINDOW_SECONDS=3600

# Hosted LLM policy. Keep disabled for public beta unless a cheap self-hosted
# provider is explicitly allowlisted.
HOSTED_LLM_MODE=disabled
HOSTED_LLM_PROVIDER_ALLOWLIST=

# Public hosted deployment guard. Set true on an internet-facing hosted Scout
# instance to expose only website/health, /v1/hosted/*, and Stripe billing
# routes. Local/admin routes such as /scrape, /crawl, /products, /run/*, /app,
# /api/config, /docs, /openapi.json, and /redoc are blocked even with X-API-Key.
SCOUT_PUBLIC_HOSTED_ONLY=false

# Server bind overrides
HOST=0.0.0.0
PORT=8421
