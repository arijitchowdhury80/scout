#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"

usage() {
  cat <<EOF
usage: scout-hosted-admin COMMAND [OPTIONS]

Admin helper for Scout hosted beta operations from the Mac.

Commands:
  generate-api-key  Generate and register a hosted API key on the VPS.
  provision-key     Generate a hosted API key on the VPS for a user or app.
  list-accounts     List hosted tenants, API-key metadata, and balances.
  list-usage        List hosted credit usage ledger entries.
  list-purchases    List Stripe checkout/package purchase records.
  list-signups      List beta API-key signup requests and delivery outcomes.
  send-test-email   Send a hosted API-key delivery smoke-test email.
  disable-access    Disable hosted access by email, tenant id, or key id.
  readiness         Check hosted health, packages, signup, checkout, and blockers.
  validate-config   Validate local SMTP/Stripe env before pushing to the VPS.
  write-config-template
                    Write a local SMTP/Stripe env template with no secrets.
  configure-production-env
                    Install allowlisted SMTP/Stripe settings on the VPS.

Examples:
  scripts/scout-hosted-admin generate-api-key --email prism@example.com --name PRISM --key-name "PRISM beta key"
  scripts/scout-hosted-admin provision-key --email prism@example.com --name PRISM --key-name "PRISM beta key"
  scripts/scout-hosted-admin list-accounts --format table
  scripts/scout-hosted-admin list-usage --format table --limit 100
  scripts/scout-hosted-admin list-usage --summary
  scripts/scout-hosted-admin list-purchases --format table
  scripts/scout-hosted-admin list-signups --format table --limit 100
  scripts/scout-hosted-admin send-test-email --email arijit@example.com --name Arijit
  scripts/scout-hosted-admin disable-access --email tester@example.com --reason "abuse report" --yes
  scripts/scout-hosted-admin readiness --require-beta-signup --require-paid-checkout
  scripts/scout-hosted-admin write-config-template --output secrets/scout-production.env
  scripts/scout-hosted-admin validate-config --secrets-file secrets/scout-production.env --require all
  scripts/scout-hosted-admin configure-production-env --secrets-file secrets/scout-production.env --restart
EOF
}

provision_key() {
  exec "$SCRIPT_DIR/scout-vps-provision-hosted-key" "$@"
}

list_accounts() {
  exec "$SCRIPT_DIR/scout-vps-list-hosted-accounts" "$@"
}

list_usage() {
  exec "$SCRIPT_DIR/scout-vps-list-hosted-usage" "$@"
}

list_purchases() {
  exec "$SCRIPT_DIR/scout-vps-list-hosted-purchases" "$@"
}

list_signups() {
  exec "$SCRIPT_DIR/scout-vps-list-hosted-signups" "$@"
}

send_test_email() {
  exec "$SCRIPT_DIR/scout-vps-send-hosted-test-email" "$@"
}

disable_access() {
  exec "$SCRIPT_DIR/scout-vps-disable-hosted-access" "$@"
}

readiness() {
  exec python3 "$SCRIPT_DIR/hosted_readiness_check.py" "$@"
}

validate_config() {
  exec "$SCRIPT_DIR/scout-validate-hosted-config" "$@"
}

write_config_template() {
  exec "$SCRIPT_DIR/scout-write-hosted-config-template" "$@"
}

configure_production_env() {
  exec "$SCRIPT_DIR/scout-vps-configure-hosted-env" "$@"
}

if [ $# -eq 0 ]; then
  usage
  exit 0
fi

case "$1" in
  -h|--help)
    usage
    exit 0
    ;;
  generate-api-key)
    shift
    provision_key "$@"
    ;;
  provision-key)
    shift
    provision_key "$@"
    ;;
  list-accounts)
    shift
    list_accounts "$@"
    ;;
  list-usage)
    shift
    list_usage "$@"
    ;;
  list-purchases)
    shift
    list_purchases "$@"
    ;;
  list-signups)
    shift
    list_signups "$@"
    ;;
  send-test-email)
    shift
    send_test_email "$@"
    ;;
  disable-access)
    shift
    disable_access "$@"
    ;;
  readiness)
    shift
    readiness "$@"
    ;;
  validate-config)
    shift
    validate_config "$@"
    ;;
  write-config-template)
    shift
    write_config_template "$@"
    ;;
  configure-production-env)
    shift
    configure_production_env "$@"
    ;;
  *)
    echo "Unknown command: $1" >&2
    usage >&2
    exit 2
    ;;
esac
