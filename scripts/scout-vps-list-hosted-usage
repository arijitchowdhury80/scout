#!/bin/sh
set -eu

HELPER_DEFAULT="/Users/arijitchowdhury/Dropbox/AI-Development/Personal/ChowMes/scripts/chowmes-ssh-helper"
ENV_DEFAULT="/Users/arijitchowdhury/Dropbox/AI-Development/Personal/ChowMes/.env.local"
HOSTED_DB="/data/hosted_accounts.sqlite"

usage() {
  cat <<EOF
usage: scout-vps-list-hosted-usage [--format table|json] [--limit N] [--email EMAIL] [--tenant-id TENANT_ID] [--summary] [--env PATH] [--helper PATH]

List Scout hosted usage ledger records from:
  $HOSTED_DB

Tables used:
  hosted_credit_ledger
  hosted_tenants

Fields shown:
  email, name, tenant_id, key_id, action, credit_type, credits,
  standard_balance_after, browser_balance_after, metadata_json, created_at
  Summary mode shows action, credit_type, event_count, credits_spent, last_used_at.

Options:
  --format FORMAT       table or json. Default: table
  --limit N             Maximum rows. Default: 100
  --email EMAIL         Filter to one hosted account email.
  --tenant-id TENANT_ID Filter to one hosted tenant id.
  --summary             Group usage by action and credit type.
  --env PATH            SSH env file for the ChowMes SSH helper. Default: $ENV_DEFAULT
  --helper PATH         SSH helper path. Default: $HELPER_DEFAULT
  -h, --help            Show this help.

Secret safety:
  This script does not print raw API keys or stored API-key hashes.
EOF
}

helper="$HELPER_DEFAULT"
env_file="$ENV_DEFAULT"
format="table"
limit="100"
email=""
tenant_id=""
summary="false"

while [ $# -gt 0 ]; do
  case "$1" in
    --format)
      if [ $# -lt 2 ]; then
        usage >&2
        exit 2
      fi
      format="$2"
      shift 2
      ;;
    --limit)
      if [ $# -lt 2 ]; then
        usage >&2
        exit 2
      fi
      limit="$2"
      shift 2
      ;;
    --email)
      if [ $# -lt 2 ]; then
        usage >&2
        exit 2
      fi
      email="$2"
      shift 2
      ;;
    --tenant-id)
      if [ $# -lt 2 ]; then
        usage >&2
        exit 2
      fi
      tenant_id="$2"
      shift 2
      ;;
    --summary)
      summary="true"
      shift
      ;;
    --env)
      if [ $# -lt 2 ]; then
        usage >&2
        exit 2
      fi
      env_file="$2"
      shift 2
      ;;
    --helper)
      if [ $# -lt 2 ]; then
        usage >&2
        exit 2
      fi
      helper="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

case "$format" in
  table|json) ;;
  *)
    echo "Unsupported --format: $format" >&2
    exit 2
    ;;
esac

case "$limit" in
  ''|*[!0-9]*)
    echo "--limit must be a positive integer." >&2
    exit 2
    ;;
esac

if [ "$limit" -lt 1 ]; then
  echo "--limit must be a positive integer." >&2
  exit 2
fi

if [ ! -x "$helper" ]; then
  echo "SSH helper is not executable: $helper" >&2
  exit 1
fi

"$helper" --env "$env_file" "sudo docker exec -i scout python3 - '$limit' '$format' '$email' '$tenant_id' '$summary' <<'PY'
import json
import sqlite3
import sys

limit = int(sys.argv[1])
output_format = sys.argv[2]
email_filter = sys.argv[3].strip().lower()
tenant_filter = sys.argv[4].strip()
summary = sys.argv[5] == 'true'

clauses = []
params = []
if email_filter:
    clauses.append('lower(t.email) = lower(?)')
    params.append(email_filter)
if tenant_filter:
    clauses.append('l.tenant_id = ?')
    params.append(tenant_filter)

where_sql = ''
if clauses:
    where_sql = 'WHERE ' + ' AND '.join(clauses)

params.append(limit)
conn = sqlite3.connect('$HOSTED_DB')
conn.row_factory = sqlite3.Row
if summary:
    rows = conn.execute(
        f'''
        SELECT
          l.action,
          l.credit_type,
          COUNT(*) AS event_count,
          SUM(l.credits) AS credits_spent,
          MAX(l.created_at) AS last_used_at
        FROM hosted_credit_ledger l
        LEFT JOIN hosted_tenants t ON t.tenant_id = l.tenant_id
        {where_sql}
        GROUP BY l.action, l.credit_type
        ORDER BY credits_spent DESC, event_count DESC
        LIMIT ?
        ''',
        params,
    ).fetchall()
else:
    rows = conn.execute(
        f'''
        SELECT
          t.email,
          t.name,
          l.tenant_id,
          l.key_id,
          l.action,
          l.credit_type,
          l.credits,
          l.standard_balance_after,
          l.browser_balance_after,
          l.metadata_json,
          l.created_at
        FROM hosted_credit_ledger l
        LEFT JOIN hosted_tenants t ON t.tenant_id = l.tenant_id
        {where_sql}
        ORDER BY l.created_at DESC
        LIMIT ?
        ''',
        params,
    ).fetchall()
records = [dict(row) for row in rows]
if output_format == 'json':
    print(json.dumps(records, indent=2, sort_keys=True))
else:
    if summary:
        headers = [
            'action',
            'credit_type',
            'event_count',
            'credits_spent',
            'last_used_at',
        ]
    else:
        headers = [
            'email',
            'name',
            'tenant_id',
            'key_id',
            'action',
            'credit_type',
            'credits',
            'standard_balance_after',
            'browser_balance_after',
            'created_at',
        ]
    print('\\t'.join(headers))
    for record in records:
        print('\\t'.join('' if record.get(header) is None else str(record.get(header)) for header in headers))
PY"
