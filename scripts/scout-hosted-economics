#!/usr/bin/env python3
"""Show non-secret Scout hosted credit package economics."""

from __future__ import annotations

import argparse
import json
import os
import shlex
import subprocess
import sys
from pathlib import Path
from typing import Any


REPO_ROOT = Path(__file__).resolve().parents[1]
if str(REPO_ROOT) not in sys.path:
    sys.path.insert(0, str(REPO_ROOT))


def _parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description=(
            "Show Scout hosted credit packages and unit economics. No secrets are read or printed."
        ),
        epilog=(
            "$10 for 1,000 standard credits. Table output includes standard_1000, "
            "gross_margin_percent, and break_even_packages_per_month."
        ),
    )
    parser.add_argument(
        "--format",
        choices=("table", "json"),
        default="table",
        help="Output format. Defaults to table.",
    )
    parser.add_argument(
        "--no-docker-fallback",
        action="store_true",
        help=argparse.SUPPRESS,
    )
    return parser


def _payload() -> dict[str, Any]:
    from scout.core.platform.pricing import (
        DEFAULT_UNIT_ECONOMICS,
        credit_packages,
        credit_policy_table,
        package_unit_economics,
    )

    packages = credit_packages()
    return {
        "headline": "$10 for 1,000 standard credits",
        "packages": [package.model_dump(mode="json") for package in packages],
        "credit_policy": [policy.model_dump(mode="json") for policy in credit_policy_table()],
        "unit_economics": {
            package.package_id: package_unit_economics(package.package_id).model_dump(mode="json")
            for package in packages
        },
        "unit_economics_assumptions": DEFAULT_UNIT_ECONOMICS.model_dump(mode="json"),
    }


def _money(cents: int | float) -> str:
    dollars = float(cents) / 100
    if dollars.is_integer():
        return f"${int(dollars)}"
    return f"${dollars:.2f}"


def _print_table(payload: dict[str, Any]) -> None:
    print("Scout hosted package economics")
    print("No secrets are read or printed.")
    print(payload["headline"])
    print()
    print(
        "package_id\tprice\tstandard_credits\tbrowser_credits\t"
        "gross_margin_percent\tbreak_even_packages_per_month"
    )
    for package in payload["packages"]:
        package_id = str(package["package_id"])
        economics = payload["unit_economics"][package_id]
        print(
            "\t".join(
                [
                    package_id,
                    _money(int(package["amount_cents"])),
                    str(package["standard_credits"]),
                    str(package["browser_credits"]),
                    f"{float(economics['gross_margin_percent']):.1f}%",
                    f"{economics['break_even_packages_per_month']} packs/month",
                ]
            )
        )
    print()
    print("Credit policy")
    for policy in payload["credit_policy"]:
        print(
            "- "
            f"{policy['action']}: {policy['credits_per_unit']} "
            f"{policy['credit_type']} credit(s) per {policy['metered_unit']}; "
            f"{policy['included_in_standard_1000']} included in a 1,000-credit pack"
        )


def main(argv: list[str] | None = None) -> int:
    args = _parser().parse_args(argv)
    if os.environ.get("SCOUT_HOSTED_ECONOMICS_FORCE_DOCKER") == "1":
        return _run_in_docker(args.format)
    try:
        payload = _payload()
    except Exception as exc:
        if args.no_docker_fallback:
            print(f"Unable to load Scout pricing model: {exc}", file=sys.stderr)
            return 1
        return _run_in_docker(args.format)
    if args.format == "json":
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        _print_table(payload)
    return 0


def _run_in_docker(output_format: str) -> int:
    """Run economics calculation inside the production Docker container."""
    docker_bin = os.environ.get("SCOUT_HOSTED_ECONOMICS_DOCKER_BIN", "sudo docker")
    command = [
        *shlex.split(docker_bin),
        "exec",
        "scout",
        "python3",
        "-c",
        _CONTAINER_CODE,
        "--format",
        output_format,
    ]
    completed = subprocess.run(command, check=False)
    return completed.returncode


_CONTAINER_CODE = r"""
import argparse
import json
from scout.core.platform.pricing import (
    DEFAULT_UNIT_ECONOMICS,
    credit_packages,
    credit_policy_table,
    package_unit_economics,
)


def money(cents):
    dollars = float(cents) / 100
    return f"${int(dollars)}" if dollars.is_integer() else f"${dollars:.2f}"


def payload():
    packages = credit_packages()
    return {
        "headline": "$10 for 1,000 standard credits",
        "packages": [package.model_dump(mode="json") for package in packages],
        "credit_policy": [policy.model_dump(mode="json") for policy in credit_policy_table()],
        "unit_economics": {
            package.package_id: package_unit_economics(package.package_id).model_dump(mode="json")
            for package in packages
        },
        "unit_economics_assumptions": DEFAULT_UNIT_ECONOMICS.model_dump(mode="json"),
    }


def table(data):
    print("Scout hosted package economics")
    print("No secrets are read or printed.")
    print(data["headline"])
    print()
    print(
        "package_id\tprice\tstandard_credits\tbrowser_credits\t"
        "gross_margin_percent\tbreak_even_packages_per_month"
    )
    for package in data["packages"]:
        package_id = str(package["package_id"])
        economics = data["unit_economics"][package_id]
        print(
            "\t".join(
                [
                    package_id,
                    money(int(package["amount_cents"])),
                    str(package["standard_credits"]),
                    str(package["browser_credits"]),
                    f"{float(economics['gross_margin_percent']):.1f}%",
                    f"{economics['break_even_packages_per_month']} packs/month",
                ]
            )
        )
    print()
    print("Credit policy")
    for policy in data["credit_policy"]:
        print(
            "- "
            f"{policy['action']}: {policy['credits_per_unit']} "
            f"{policy['credit_type']} credit(s) per {policy['metered_unit']}; "
            f"{policy['included_in_standard_1000']} included in a 1,000-credit pack"
        )


parser = argparse.ArgumentParser()
parser.add_argument("--format", choices=("table", "json"), default="table")
args = parser.parse_args()
data = payload()
if args.format == "json":
    print(json.dumps(data, indent=2, sort_keys=True))
else:
    table(data)
"""


if __name__ == "__main__":
    raise SystemExit(main())
