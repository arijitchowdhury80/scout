#!/usr/bin/env python3
"""Validate Scout hosted SMTP and Stripe config without printing secrets."""

from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path


BETA_REQUIRED_KEYS = [
    "HOSTED_BETA_SIGNUP_ENABLED",
    "HOSTED_KEY_DELIVERY_SMTP_HOST",
    "HOSTED_KEY_DELIVERY_SMTP_PORT",
    "HOSTED_KEY_DELIVERY_SMTP_FROM_EMAIL",
    "HOSTED_KEY_DELIVERY_SMTP_USERNAME",
    "HOSTED_KEY_DELIVERY_SMTP_PASSWORD",
]

PAID_REQUIRED_KEYS = [
    *BETA_REQUIRED_KEYS,
    "STRIPE_SECRET_KEY",
    "STRIPE_STANDARD_1000_PRICE_ID",
    "STRIPE_STANDARD_3000_PRICE_ID",
    "STRIPE_STANDARD_15000_PRICE_ID",
    "STRIPE_SUCCESS_URL",
    "STRIPE_CANCEL_URL",
    "STRIPE_WEBHOOK_SECRET",
]

BOOLEAN_KEYS = {
    "HOSTED_BETA_SIGNUP_ENABLED",
    "HOSTED_KEY_DELIVERY_SMTP_USE_TLS",
}

SECRET_MARKERS = ("sk_test_", "sk_live_", "whsec_", "smtp-secret", "scout_live_")


def parse_env_file(path: Path) -> dict[str, str]:
    """Parse a simple KEY=value env file."""
    values: dict[str, str] = {}
    for raw_line in path.read_text(encoding="utf-8").splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, value = line.split("=", 1)
        key = key.strip()
        value = _strip_quotes(value.strip())
        values[key] = value
    return values


def _strip_quotes(value: str) -> str:
    """Remove matching shell-style wrapper quotes."""
    if len(value) >= 2 and value[0] == value[-1] and value[0] in {"'", '"'}:
        return value[1:-1]
    return value


def validate_config(values: dict[str, str], requirement: str) -> tuple[list[str], list[str]]:
    """Return missing keys and validation warnings for a requirement level."""
    required = required_keys(requirement)
    missing = [key for key in required if values.get(key, "").strip() == ""]
    warnings: list[str] = []

    if values.get("HOSTED_BETA_SIGNUP_ENABLED", "").casefold() not in {"true", "1", "yes"}:
        missing.append("HOSTED_BETA_SIGNUP_ENABLED=true")

    smtp_port = values.get("HOSTED_KEY_DELIVERY_SMTP_PORT", "")
    if smtp_port and not smtp_port.isdigit():
        warnings.append("HOSTED_KEY_DELIVERY_SMTP_PORT should be an integer.")

    for key in BOOLEAN_KEYS:
        value = values.get(key, "")
        if value and value.casefold() not in {"true", "false", "1", "0", "yes", "no"}:
            warnings.append(f"{key} should be true or false.")

    username = values.get("HOSTED_KEY_DELIVERY_SMTP_USERNAME", "")
    password = values.get("HOSTED_KEY_DELIVERY_SMTP_PASSWORD", "")
    if username and not password:
        missing.append("HOSTED_KEY_DELIVERY_SMTP_PASSWORD")
    if password and not username:
        missing.append("HOSTED_KEY_DELIVERY_SMTP_USERNAME")

    if requirement in {"paid", "all"}:
        for url_key in ["STRIPE_SUCCESS_URL", "STRIPE_CANCEL_URL"]:
            value = values.get(url_key, "")
            if value and not value.startswith("https://"):
                warnings.append(f"{url_key} should use https:// for hosted production.")

    return sorted(set(missing)), warnings


def required_keys(requirement: str) -> list[str]:
    """Return keys required for beta signup, paid checkout, or both."""
    if requirement == "beta":
        return BETA_REQUIRED_KEYS
    if requirement in {"paid", "all"}:
        return PAID_REQUIRED_KEYS
    raise ValueError(f"Unsupported requirement: {requirement}")


def assert_no_secret_leak(text: str) -> None:
    """Defensive guard for script output generation."""
    leaked = [marker for marker in SECRET_MARKERS if marker in text]
    if leaked:
        raise RuntimeError("Refusing to print secret-looking hosted config output.")


def build_parser() -> argparse.ArgumentParser:
    """Build CLI parser."""
    parser = argparse.ArgumentParser(
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
epilog="""Required key groups:
  beta: HOSTED_BETA_SIGNUP_ENABLED, HOSTED_KEY_DELIVERY_SMTP_HOST,
        HOSTED_KEY_DELIVERY_SMTP_PORT, HOSTED_KEY_DELIVERY_SMTP_FROM_EMAIL,
        HOSTED_KEY_DELIVERY_SMTP_USERNAME, HOSTED_KEY_DELIVERY_SMTP_PASSWORD
  paid: beta keys plus STRIPE_SECRET_KEY, STRIPE_STANDARD_1000_PRICE_ID,
        STRIPE_STANDARD_3000_PRICE_ID, STRIPE_STANDARD_15000_PRICE_ID,
        STRIPE_SUCCESS_URL, STRIPE_CANCEL_URL, STRIPE_WEBHOOK_SECRET
""",
    )
    parser.add_argument("--secrets-file", required=True, help="Local hosted env file to validate.")
    parser.add_argument(
        "--require",
        choices=["beta", "paid", "all"],
        default="all",
        help="Validation level. Default: all.",
    )
    parser.add_argument("--json", action="store_true", help="Print machine-readable JSON.")
    return parser


def main(argv: list[str] | None = None) -> int:
    """Validate a hosted config file."""
    args = build_parser().parse_args(argv)
    path = Path(args.secrets_file)
    if not path.exists():
        print(f"Secrets file not found: {path}", file=sys.stderr)
        return 2

    values = parse_env_file(path)
    missing, warnings = validate_config(values, args.require)
    present = [key for key in required_keys(args.require) if values.get(key, "").strip()]
    payload = {
        "require": args.require,
        "valid": not missing and not warnings,
        "present_keys": present,
        "missing_keys": missing,
        "warnings": warnings,
    }
    if args.json:
        output = json.dumps(payload, indent=2, sort_keys=True)
    elif missing or warnings:
        lines = [f"Hosted config validation failed for: {args.require}"]
        if missing:
            lines.append("Missing required hosted config keys:")
            lines.extend(f"  - {key}" for key in missing)
        if warnings:
            lines.append("Warnings:")
            lines.extend(f"  - {warning}" for warning in warnings)
        output = "\n".join(lines)
    else:
        lines = [f"Hosted config validation passed for: {args.require}", "Present required keys:"]
        lines.extend(f"  - {key}" for key in present)
        output = "\n".join(lines)

    assert_no_secret_leak(output)
    stream = sys.stdout if payload["valid"] else sys.stderr
    print(output, file=stream)
    return 0 if payload["valid"] else 2


if __name__ == "__main__":
    raise SystemExit(main())
