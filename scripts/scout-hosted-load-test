def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description="Simulate hosted Scout beta users across the hosted HTTP surface.",
        formatter_class=argparse.ArgumentDefaultsHelpFormatter,
        epilog=(
            "Endpoint plan: /v1/hosted/me, /v1/hosted/scrape, "
            "/v1/hosted/crawl, /v1/hosted/products, /v1/hosted/run/company, "
            "/v1/hosted/run/prism, /v1/hosted/run/investor, "
            "/v1/hosted/run/careers, /v1/hosted/run/jobs, "
            "/v1/hosted/run/news, /v1/hosted/run/research, "
            "/v1/hosted/run/docs, /v1/hosted/run/social, "
            "/v1/hosted/run/locations, /v1/hosted/run/website-quality, "
            "/v1/hosted/runs. Add --include-playground for all public "
            "/v1/playground/run workflows."
        ),
    )
    parser.add_argument("--base-url", required=True, help="Hosted Scout base URL.")
    parser.add_argument("--api-key", default="", help="Bearer key to reuse for all users.")
    parser.add_argument(
        "--api-key-file",
        type=Path,
        help="File containing one Bearer key per line. Keys cycle if fewer than users.",
    )
    parser.add_argument("--users", type=int, default=250, help="Concurrent beta users.")
    parser.add_argument(
        "--concurrency",
        type=int,
        default=250,
        help="Maximum simultaneous HTTP requests.",
    )
    parser.add_argument("--timeout", type=float, default=60.0, help="Per-request timeout.")
    parser.add_argument("--p95-ms", type=int, default=15000, help="P95 latency pass threshold.")
    parser.add_argument(
        "--max-error-rate",
        type=float,
        default=0.02,
        help="Maximum allowed non-2xx/exception rate.",
    )
    parser.add_argument("--dry-run", action="store_true", help="Print the plan without traffic.")
    parser.add_argument(
        "--include-playground",
        action="store_true",
        help="Also exercise anonymous playground workflows with realistic targets.",
    )
    return parser


def dry_run_payload(args: argparse.Namespace) -> dict[str, Any]:
    return {
        "base_url": args.base_url.rstrip("/"),
        "users": args.users,
        "concurrency": args.concurrency,
        "requests_per_user": len(request_plan(args)),
        "total_planned_requests": args.users * len(request_plan(args)),
        "endpoints": [item.label for item in PLAN],
        "playground_endpoints": [item.body["workflow"] for item in PLAYGROUND_PLAN]
        if args.include_playground
        else [],
        "targets": {
            "scrape_crawl_map": "https://www.wikimedia.org/",
            "screenshot": "https://www.cnn.com/",
            "products": "https://www.lacoste.com/us/",
            "intelligence": "https://www.microsoft.com/",
        },
        "llm_expected": "disabled",
        "notes": [
            "Use a dedicated beta key pool for live production tests.",
            "This script proves capacity only for the target, hardware, config, and keys tested.",
        ],
    }


def request_plan(args: argparse.Namespace) -> list[PlannedRequest]:
    plan = list(PLAN)
    if args.include_playground:
        plan.extend(PLAYGROUND_PLAN)
    return plan


def load_keys(args: argparse.Namespace) -> list[str]:
    keys: list[str] = []
    if args.api_key:
        keys.append(args.api_key.strip())
    if args.api_key_file:
        keys.extend(
            line.strip()
            for line in args.api_key_file.read_text(encoding="utf-8").splitlines()
            if line.strip()
        )
    return [key for key in keys if key]


def perform_request(
    *,
    base_url: str,
    key: str,
    planned: PlannedRequest,
    timeout: float,
    user_index: int,
) -> dict[str, Any]:
    started = time.monotonic()
    url = f"{base_url}{planned.path}"
    simulated_ip = f"198.51.{user_index // 250}.{(user_index % 250) + 1}"
    headers = {
        "Authorization": f"Bearer {key}",
        "User-Agent": "scout-hosted-load-test/1.0",
        "X-Forwarded-For": simulated_ip,
    }
    data = None
    if planned.body is not None:
        body = dict(planned.body)
        if planned.path == "/v1/hosted/run/company":
            body["query"] = f"Example Domain user {user_index}"
        data = json.dumps(body).encode("utf-8")
        headers["Content-Type"] = "application/json"
    req = urllib.request.Request(url, data=data, headers=headers, method=planned.method)
    try:
        with urllib.request.urlopen(req, timeout=timeout) as response:
            response.read(2048)
            status: int | str = response.status
            error = ""
    except urllib.error.HTTPError as exc:
        exc.read(2048)
        status = exc.code
        error = str(exc)
    except Exception as exc:  # noqa: BLE001 - load tool reports all request failures.
        status = "ERR"
        error = repr(exc)
    elapsed_ms = int((time.monotonic() - started) * 1000)
    ok = isinstance(status, int) and 200 <= status < 300
    return {
        "endpoint": planned.label,
        "status": status,
        "ok": ok,
        "latency_ms": elapsed_ms,
        "error": error,
    }


async def run_load(args: argparse.Namespace, keys: list[str]) -> dict[str, Any]:
    base_url = args.base_url.rstrip("/")
    semaphore = asyncio.Semaphore(args.concurrency)
    tasks = []

    async def one(user_index: int, planned: PlannedRequest) -> dict[str, Any]:
        async with semaphore:
            key = keys[user_index % len(keys)]
            return await asyncio.to_thread(
                perform_request,
                base_url=base_url,
                key=key,
                planned=planned,
                timeout=args.timeout,
                user_index=user_index,
            )

    for user_index in range(args.users):
        for planned in request_plan(args):
            tasks.append(asyncio.create_task(one(user_index, planned)))

    started = time.monotonic()
    results = await asyncio.gather(*tasks)
    duration_seconds = time.monotonic() - started
    latencies = [item["latency_ms"] for item in results]
    failures = [item for item in results if not item["ok"]]
    p95 = statistics.quantiles(latencies, n=100)[94] if len(latencies) >= 100 else max(latencies)
    error_rate = len(failures) / len(results) if results else 1.0
    by_endpoint: dict[str, dict[str, int]] = {}
    for item in results:
        endpoint = item["endpoint"]
        current = by_endpoint.setdefault(endpoint, {"total": 0, "ok": 0, "failed": 0})
        current["total"] += 1
        current["ok" if item["ok"] else "failed"] += 1
    passed = error_rate <= args.max_error_rate and p95 <= args.p95_ms
    return {
        "passed": passed,
        "users": args.users,
        "concurrency": args.concurrency,
        "total_requests": len(results),
        "duration_seconds": round(duration_seconds, 2),
        "requests_per_second": round(len(results) / duration_seconds, 2)
        if duration_seconds
        else 0,
        "p95_latency_ms": int(p95),
        "error_rate": round(error_rate, 4),
        "thresholds": {"p95_ms": args.p95_ms, "max_error_rate": args.max_error_rate},
        "by_endpoint": by_endpoint,
        "sample_failures": failures[:10],
    }


def main(argv: list[str] | None = None) -> int:
    args = build_parser().parse_args(argv)
    if args.users < 1 or args.concurrency < 1:
        print("--users and --concurrency must be positive.", file=sys.stderr)
        return 2
    if args.dry_run:
        print(json.dumps(dry_run_payload(args), indent=2))
        return 0
    keys = load_keys(args)
    if not keys:
        print("--api-key or --api-key-file is required for live load tests.", file=sys.stderr)
        return 2
    loop = asyncio.new_event_loop()
    try:
        loop.set_default_executor(ThreadPoolExecutor(max_workers=args.concurrency))
        report = loop.run_until_complete(run_load(args, keys))
    finally:
        loop.close()
    print(json.dumps(report, indent=2))
    return 0 if report["passed"] else 1


if __name__ == "__main__":
    raise SystemExit(main())
