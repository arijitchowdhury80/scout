#!/bin/sh
set -eu

HELPER_DEFAULT="/Users/arijitchowdhury/Dropbox/AI-Development/Personal/ChowMes/scripts/chowmes-ssh-helper"
ENV_DEFAULT="/Users/arijitchowdhury/Dropbox/AI-Development/Personal/ChowMes/.env.local"

usage() {
  cat <<EOF
usage: scout-vps-send-hosted-test-email --email EMAIL [--name NAME] [--env PATH] [--helper PATH]

Send a Scout hosted API-key delivery smoke-test email through the running VPS
container.

No hosted account is created. No credits are granted. No real API key is issued.
The running Scout container requires HOSTED_KEY_DELIVERY_SMTP_HOST, HOSTED_KEY_DELIVERY_SMTP_FROM_EMAIL,
HOSTED_KEY_DELIVERY_SMTP_USERNAME, and HOSTED_KEY_DELIVERY_SMTP_PASSWORD before
hosted key delivery is considered configured.

Options:
  --email EMAIL  Recipient for the smoke-test email. Required.
  --name NAME    Recipient display name.
  --env PATH     SSH env file for the ChowMes SSH helper. Default: $ENV_DEFAULT
  --helper PATH  SSH helper path. Default: $HELPER_DEFAULT
  -h, --help     Show this help.

Secret safety:
  This command does not print SMTP passwords, raw API keys, or key hashes.
  It sends using smoke_test=True and raw_api_key='' so the email cannot be
  mistaken for a real hosted Scout key.
EOF
}

helper="$HELPER_DEFAULT"
env_file="$ENV_DEFAULT"
email=""
name=""

while [ $# -gt 0 ]; do
  case "$1" in
    --email)
      if [ $# -lt 2 ]; then
        usage >&2
        exit 2
      fi
      email="$2"
      shift 2
      ;;
    --name)
      if [ $# -lt 2 ]; then
        usage >&2
        exit 2
      fi
      name="$2"
      shift 2
      ;;
    --env)
      if [ $# -lt 2 ]; then
        usage >&2
        exit 2
      fi
      env_file="$2"
      shift 2
      ;;
    --helper)
      if [ $# -lt 2 ]; then
        usage >&2
        exit 2
      fi
      helper="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

if [ -z "$email" ]; then
  echo "Missing --email." >&2
  usage >&2
  exit 2
fi

if [ ! -x "$helper" ]; then
  echo "SSH helper is not executable: $helper" >&2
  exit 1
fi

encoded_email="$(printf '%s' "$email" | base64 | tr -d '\n')"
encoded_name="$(printf '%s' "$name" | base64 | tr -d '\n')"

"$helper" --env "$env_file" "sudo docker exec -i scout python3 - '$encoded_email' '$encoded_name' <<'PY'
import base64
import sys

from scout.api.config import settings
from scout.core.platform.hosted import HostedPlan
from scout.core.platform.key_delivery import (
    HostedApiKeyDeliveryRequest,
    SmtpHostedApiKeyDeliveryConfig,
    SmtpHostedApiKeyDeliveryService,
)

email = base64.b64decode(sys.argv[1]).decode('utf-8')
name = base64.b64decode(sys.argv[2]).decode('utf-8')
service = SmtpHostedApiKeyDeliveryService(
    SmtpHostedApiKeyDeliveryConfig(
        host=settings.hosted_key_delivery_smtp_host,
        port=settings.hosted_key_delivery_smtp_port,
        from_email=settings.hosted_key_delivery_smtp_from_email,
        username=settings.hosted_key_delivery_smtp_username,
        password=settings.hosted_key_delivery_smtp_password,
        use_tls=settings.hosted_key_delivery_smtp_use_tls,
    )
)
result = service.deliver(
    HostedApiKeyDeliveryRequest(
        email=email,
        name=name,
        tenant_id='smtp_smoke_test',
        key_id='smtp_smoke_test',
        plan=HostedPlan.HOSTED_BETA_PASS,
        raw_api_key='',
        checkout_session_id='smtp_smoke_test',
        smoke_test=True,
    )
)
if not result.delivered:
    raise SystemExit(f'FAILED: {result.reason}')
print(f'DELIVERED: smoke-test email sent to {email}')
PY"
